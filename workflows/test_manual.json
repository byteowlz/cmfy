      "default": "12345",
      "description": "Random seed"
    },
    "STEPS": {
      "default": "20",
      "description": "Number of steps"
    },
    "CFG": {
      "default": "7.0"
    },
    "PROMPT": {
      "default": "a beautiful landscape",
      "description": "Main prompt text"
    }
  }
}
