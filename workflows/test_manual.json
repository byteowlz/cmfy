{
  "prompt": {
    "3": {
      "inputs": {
        "seed": "${SEED}",
        "steps": "${STEPS}",
        "cfg": "${CFG}",
        "text": "test"
      },
      "class_type": "KSampler"
    },
    "6": {
      "inputs": {
        "text": "${PROMPT}"
      },
      "class_type": "CLIPTextEncode"
    }
  },
  "variables": {
